{
  "name": "prompt-translator",
  "version": "1.0.0",
  "description": "Local Persian to English Prompt Translator using Ollama",
  "main": "main.js",
  "scripts": {
    "postinstall": "node scripts/ensure-electron.js",
    "start": "electron .",
    "build": "node scripts/build.js",
    "build:win": "node scripts/build.js win",
    "build:mac": "node scripts/build.js mac",
    "run:win": "node scripts/run-built.js"
  },
  "build": {
    "electronDist": "node_modules/electron/dist",
    "appId": "com.alimortazavi.prompttranslator",
    "productName": "Prompt Translator",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    }
  },
  "keywords": [
    "electron",
    "ollama",
    "translator",
    "prompt"
  ],
  "author": "Alimortazavi",
  "license": "MIT",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1"
  }
}
